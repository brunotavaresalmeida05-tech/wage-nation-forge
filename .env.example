# WageCompany — Variáveis de Ambiente
# Copia este ficheiro para .env.local e preenche com os valores reais
# NUNCA commitar .env.local — apenas este .env.example vai para o git

# ── Supabase ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://XXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Apenas em Edge Functions (servidor) — NUNCA com prefixo VITE_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Clerk Auth ───────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Encriptação ──────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Guardar em lugar seguro — sem esta chave os dados encriptados são irrecuperáveis
APP_ENCRYPTION_KEY=gerar_com_comando_acima

# ── Blockchain ───────────────────────────────────────────
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
VITE_WAGE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Apenas em Edge Functions — NUNCA com prefixo VITE_
DEPLOYER_PRIVATE_KEY=0x...
